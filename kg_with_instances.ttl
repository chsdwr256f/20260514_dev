@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:AdmissionRequirement a owl:Class ;
    rdfs:subClassOf :Requirement .

:CourseRequirement a owl:Class ;
    rdfs:subClassOf :Requirement .

:EntryRequirement a owl:Class ;
    rdfs:subClassOf :Requirement .

:appliesToCourse a owl:ObjectProperty ;
    rdfs:label "applies to course" ;
    rdfs:domain :Course ;
    rdfs:range :AssessmentPolicy ;
    rdfs:subPropertyOf owl:topObjectProperty .

:appliesToProgramme a owl:ObjectProperty ;
    rdfs:label "applies to programme" ;
    rdfs:domain :Programme ;
    rdfs:range :AssessmentPolicy ;
    rdfs:subPropertyOf owl:topObjectProperty .

:happens_in_year a owl:ObjectProperty ;
    rdfs:label "happens in year" ;
    rdfs:domain :Event,
        :Publication,
        :ResearchProject,
        :Scholarship ;
    rdfs:range :AcademicYear .

:hasPrerequisite a owl:ObjectProperty ;
    rdfs:label "has prerequisite" ;
    rdfs:comment "Specifies that completion of one course is required before undertaking another course." ;
    rdfs:domain :AcademicEntity ;
    rdfs:range :Course ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasStaffMember a owl:ObjectProperty ;
    rdfs:label "has staff member" ;
    rdfs:domain :OrganisationUnit ;
    rdfs:range :Staff .

:has_role a owl:ObjectProperty ;
    rdfs:label "has role" .

:memberOf a owl:ObjectProperty ;
    rdfs:label "member of" ;
    rdfs:comment "Indicates that a person belongs to a specific organisational unit within the institution." ;
    rdfs:domain :Staff,
        :Student ;
    rdfs:range :OrganisationUnit ;
    rdfs:subPropertyOf owl:topObjectProperty .

:offersProgramme a owl:ObjectProperty ;
    rdfs:label "offers programme" ;
    rdfs:comment "Relates a school to a programme that it offers." ;
    rdfs:domain :College,
        :School ;
    rdfs:range :Programme ;
    rdfs:subPropertyOf owl:topObjectProperty .

:partOfSchool a owl:ObjectProperty ;
    rdfs:label "past of school" ;
    rdfs:domain :School ;
    rdfs:range :Department ;
    rdfs:subPropertyOf owl:topObjectProperty .

:relatedToTopic a owl:ObjectProperty ;
    rdfs:label "related to topic" ;
    rdfs:comment "Associates an entity with a topic that represents its subject area, expertise, or thematic focus." ;
    rdfs:domain :AcademicEntity,
        :Document,
        :Policy,
        :Publication,
        :Regulation,
        :ResearchProject,
        :WebPage ;
    rdfs:range :Topic ;
    rdfs:subPropertyOf owl:topObjectProperty .

